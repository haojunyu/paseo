{
  "apiType": "stageMode",
  "buildOption": {
    "arkOptions": {
      "runtimeOnly": {
        // Allow importing .js / .d.ts from npm packages
        "packages": [
          "@getpaseo/client",
          "@getpaseo/protocol",
          "@getpaseo/highlight",
          "markdown-it",
          "zod",
          "mnemonic-id"
        ]
      }
    }
  },
  "buildOptionSet": [
    {
      "name": "release",
      "arkOptions": {
        "obfuscation": {
          "enable": false
        }
      }
    }
  ],
  "targets": [
    {
      "name": "default"
    }
  ]
}
